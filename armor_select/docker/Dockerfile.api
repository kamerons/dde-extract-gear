FROM python:3.11-slim

WORKDIR /app

# Copy requirements and install dependencies
COPY requirements.txt /app/
RUN pip install --no-cache-dir -r requirements.txt

# Copy the armor_select package
COPY armor_select/ /app/armor_select/

# Expose API port
EXPOSE 8000

# Run the API server
# Use --reload flag for development (override in docker-compose.dev.yml)
CMD ["uvicorn", "armor_select.api.main:app", "--host", "0.0.0.0", "--port", "8000"]
