FROM python:3.11-slim

WORKDIR /app

# Copy API-only requirements (no TensorFlow; NN runs in task container)
COPY requirements-api.txt /app/
RUN pip install --no-cache-dir -r requirements-api.txt

# Copy application packages
COPY api/ /app/api/
COPY shared/ /app/shared/
COPY task/ /app/task/

# Expose API port
EXPOSE 8000

# Run the API server
# Use --reload flag for development (override in docker-compose.dev.yml)
CMD ["uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8000"]
